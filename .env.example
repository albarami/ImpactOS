# ImpactOS Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# =============================================================================
# Environment Profile (REQUIRED — controls auth/security behavior)
# =============================================================================
# dev      → HS256 self-signed JWT, dev auth stub, local providers OK
# staging  → RS256 external IdP, real providers required, fail-closed
# prod     → RS256 external IdP, real providers required, fail-closed
ENVIRONMENT=dev

# =============================================================================
# Database (Postgres 16 + pgvector)
# =============================================================================
# Dev:     postgresql+asyncpg://impactos:impactos@localhost:5432/impactos
# Docker:  postgresql+asyncpg://impactos:impactos@postgres:5432/impactos
# Staging: postgresql+asyncpg://USER:PASS@staging-db-host:5432/impactos
DATABASE_URL=postgresql+asyncpg://impactos:impactos@localhost:5432/impactos

# =============================================================================
# Redis (broker + cache)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Celery (job queue broker)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0

# =============================================================================
# Object Storage (MinIO / S3)
# =============================================================================
# Dev:     ./uploads (local filesystem)
# Staging: s3://impactos-staging-bucket or /mnt/storage
# Prod:    s3://impactos-prod-bucket
OBJECT_STORAGE_PATH=./uploads
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=impactos
MINIO_SECRET_KEY=impactos-secret
MINIO_BUCKET=impactos-data
MINIO_USE_SSL=false

# =============================================================================
# LLM API Keys (leave empty for local-only mode)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# Document Extraction
# =============================================================================
# Dev:     local (no Azure credentials needed)
# Staging: azure_di (requires AZURE_DI_ENDPOINT + AZURE_DI_KEY)
EXTRACTION_PROVIDER=local
# AZURE_DI_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com
# AZURE_DI_KEY=REPLACE_ME

# =============================================================================
# Security — Token Signing
# =============================================================================
# Dev:     dev-secret-change-in-production (accepted only in dev)
# Staging: MUST be a unique strong secret (rejected if dev default)
# Prod:    MUST be a unique strong secret (rejected if dev default)
SECRET_KEY=dev-secret-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# External IdP — JWT Validation (REQUIRED for staging/prod)
# =============================================================================
# Dev:     leave empty (dev stub uses HS256 with SECRET_KEY)
# Staging: MUST be set (fail-closed if missing)
# Prod:    MUST be set (fail-closed if missing)
JWT_ISSUER=
JWT_AUDIENCE=
JWKS_URL=
# Example staging/prod values:
# JWT_ISSUER=https://your-idp.example.com
# JWT_AUDIENCE=impactos-api
# JWKS_URL=https://your-idp.example.com/.well-known/jwks.json

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
