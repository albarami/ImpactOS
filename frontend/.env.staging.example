# ─────────────────────────────────────────────────────────
# ImpactOS Frontend — Staging Environment Variables
# ─────────────────────────────────────────────────────────
# Copy to frontend/.env.staging and fill in real values.
# All REPLACE_ / YOUR_ values MUST be replaced before deployment.

# ── API Backend URL ──────────────────────────────────────
# Points to the staging API server. Must be reachable from
# both the Next.js server (SSR) and the client browser.
NEXT_PUBLIC_API_URL=http://api:8000

# ── NextAuth Configuration ───────────────────────────────
# NEXTAUTH_URL: canonical URL of the frontend (used for callbacks)
NEXTAUTH_URL=https://REPLACE_WITH_STAGING_FRONTEND_URL

# NEXTAUTH_SECRET: strong random secret for session encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=REPLACE_WITH_STRONG_NEXTAUTH_SECRET

# ── Auth Provider ────────────────────────────────────────
# "oidc" for real IdP (staging/prod), "credentials" for dev only.
NEXTAUTH_PROVIDER=oidc

# ── OIDC Provider Configuration ─────────────────────────
# Required when NEXTAUTH_PROVIDER=oidc.
# Works with Azure AD, Auth0, Keycloak, or any OIDC-compliant IdP.
# OIDC_ISSUER must match JWT_ISSUER on the backend.
OIDC_ISSUER=https://REPLACE_WITH_IDP_ISSUER_URL
OIDC_CLIENT_ID=REPLACE_WITH_OIDC_CLIENT_ID
OIDC_CLIENT_SECRET=REPLACE_WITH_OIDC_CLIENT_SECRET

# ── Auth Mode (client-side) ─────────────────────────────
# Controls login page UI: "oidc" shows SSO button, "credentials" shows email form.
NEXT_PUBLIC_AUTH_MODE=oidc

# ── Workspace (optional) ────────────────────────────────
# Default workspace for dev convenience. Not used in staging.
# NEXT_PUBLIC_DEV_WORKSPACE_ID=
