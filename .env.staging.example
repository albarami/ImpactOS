# ImpactOS — Staging Environment Variables
#
# Copy to .env.staging and fill in ALL values.
# NEVER commit .env.staging — it contains secrets.
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml up -d
#
# All variables below are REQUIRED for staging. The application will
# refuse to start (fail-closed) if any are missing or use dev defaults.

# =============================================================================
# Environment Profile (DO NOT CHANGE)
# =============================================================================
ENVIRONMENT=staging

# =============================================================================
# Database (Postgres 16 + pgvector)
# =============================================================================
# MUST NOT contain "localhost" or "changeme" — fail-closed
POSTGRES_USER=impactos_staging
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=impactos
DATABASE_URL=postgresql+asyncpg://impactos_staging:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/impactos

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0

# =============================================================================
# Object Storage (MinIO / S3)
# =============================================================================
# MUST be an absolute path or S3 URI — relative paths rejected in staging
OBJECT_STORAGE_PATH=/data/impactos-storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=REPLACE_WITH_STAGING_ACCESS_KEY
MINIO_SECRET_KEY=REPLACE_WITH_STAGING_SECRET_KEY
MINIO_BUCKET=impactos-data
MINIO_USE_SSL=false

# =============================================================================
# Security — Token Signing
# =============================================================================
# MUST be a strong, unique secret — dev default rejected in staging
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY

# =============================================================================
# External IdP — JWT Validation (REQUIRED for staging)
# =============================================================================
# All three MUST be set — fail-closed 401 if missing
JWT_ISSUER=https://your-idp.example.com
JWT_AUDIENCE=impactos-api
JWKS_URL=https://your-idp.example.com/.well-known/jwks.json

# =============================================================================
# CORS
# =============================================================================
ALLOWED_ORIGINS=https://staging.impactos.example.com

# =============================================================================
# LLM API Keys (optional — copilot SKIP if absent)
# =============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# =============================================================================
# Document Extraction
# =============================================================================
# Use azure_di for production-grade PDF extraction
EXTRACTION_PROVIDER=local
# AZURE_DI_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com
# AZURE_DI_KEY=REPLACE_ME

# =============================================================================
# Copilot
# =============================================================================
COPILOT_ENABLED=true

# =============================================================================
# Frontend (required when deploying with --profile frontend-staging)
# =============================================================================
# NEXTAUTH_URL: canonical frontend URL (used for OAuth callbacks)
NEXTAUTH_URL=https://REPLACE_WITH_STAGING_FRONTEND_URL
# NEXTAUTH_SECRET: strong random secret for session encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=REPLACE_WITH_STRONG_NEXTAUTH_SECRET
# Auth provider: "oidc" for real IdP, "credentials" for dev only
NEXTAUTH_PROVIDER=oidc
# OIDC client credentials (from your IdP — must match JWT_ISSUER above)
OIDC_ISSUER=https://your-idp.example.com
OIDC_CLIENT_ID=REPLACE_WITH_OIDC_CLIENT_ID
OIDC_CLIENT_SECRET=REPLACE_WITH_OIDC_CLIENT_SECRET
# Client-side auth mode: controls login page UI
NEXT_PUBLIC_AUTH_MODE=oidc
# API URL as seen by the frontend container (Docker networking)
NEXT_PUBLIC_API_URL=http://api:8000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
